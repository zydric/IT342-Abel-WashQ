<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="400dp"
    android:height="240dp"
    android:viewportWidth="400"
    android:viewportHeight="240">

    <!-- Base Gradient with Wave -->
    <path
        android:pathData="M 0,0 H 400 V 180 Q 200,260 0,180 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:angle="0"
                android:endColor="@color/accent"
                android:startColor="@color/primary_dark"
                android:type="linear" />
        </aapt:attr>
    </path>

    <!-- Secondary Wave Overlay for Depth -->
    <path
        android:pathData="M 0,0 H 400 V 140 Q 250,220 0,140 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:angle="90"
                android:endColor="#44FFFFFF"
                android:startColor="#11FFFFFF"
                android:type="linear" />
        </aapt:attr>
    </path>
    
</vector>
