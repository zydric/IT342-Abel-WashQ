<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.WashQ" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/surface</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/surface</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorError">@color/error</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <item name="materialButtonStyle">@style/WashQ.MaterialButton</item>
        <item name="textInputStyle">@style/WashQ.TextInputLayout</item>
        <item name="snackbarStyle">@style/WashQ.Snackbar</item>
    </style>

    <style name="Theme.Mobile" parent="Theme.WashQ" />

    <style name="WashQ.MaterialButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.09</item>
    </style>

    <style name="WashQ.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="shapeAppearanceOverlay">@style/WashQ.ShapeAppearance.Corner.Small</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeErrorColor">@color/error</item>
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="hintTextColor">@color/text_muted</item>
    </style>

    <style name="WashQ.ShapeAppearance.Corner.Small" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/button_corner_radius</item>
    </style>

    <style name="WashQ.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/surface_dark</item>
        <item name="actionTextColorAlpha">1</item>
    </style>

    <style name="WashQ.BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#331D4ED8</item>
        <item name="shapeAppearance">@style/WashQ.ShapeAppearance.Corner.Small</item>
    </style>
</resources>